# ═════════════════════════════════════════════════════════════
# TICKETS SERVICE - CONFIGURACIÓN (.env.example)
# ═════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura los valores

PORT=3004

# ─── DATABASE CONFIGURATION (PostgreSQL) ─────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USUARIO=postgres
DB_CONTRASENA=tu_contrasena_aqui
DB_NOMBRE=db_tickets

# ─── JWT CONFIGURATION ────────────────────────────────────────
# DEBE SER IGUAL AL JWT_SECRET de backend-personas
JWT_SECRET=cambia-esto-por-algo-largo-y-aleatorio-para-produccion

# ─── MICROSERVICES URLs ───────────────────────────────────────
PERSONAS_SERVICE_URL=http://localhost:3001
VEHICULOS_SERVICE_URL=http://localhost:3002
ZONAS_SERVICE_URL=http://localhost:3003
