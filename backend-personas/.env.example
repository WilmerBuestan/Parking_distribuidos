# ═════════════════════════════════════════════════════════════
# BACKEND PERSONAS - CONFIGURACIÓN (.env.example)
# ═════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura los valores

# PORT (opcional, por defecto 3001)
PORT=3001

# ─── DATABASE CONFIGURATION (PostgreSQL) ─────────────────────
# Cambia estos valores según tu configuración local
DB_HOST=localhost
DB_PORT=5432
DB_USUARIO=postgres
DB_CONTRASENA=tu_contrasena_aqui
DB_NOMBRE=db_personas

# ─── JWT CONFIGURATION ────────────────────────────────────────
# IMPORTANTE: Generar una clave segura en producción
JWT_SECRET=cambia-esto-por-algo-largo-y-aleatorio-para-produccion
JWT_ACCESS_EXPIRES_IN=20m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MICROSERVICES URLs ───────────────────────────────────────
VEHICULOS_SERVICE_URL=http://localhost:3002
ASIGNACIONES_SERVICE_URL=http://localhost:3005
